# --- BBO. Backend Environment Variables ---
# Django Settings
DJANGO_SECRET_KEY=your-super-secret-key-goes-here
DEBUG=True

# Database Configuration (PostgreSQL/Supabase)
# Option A: Individual Variables (Standard for Local/Docker)
DB_NAME=postgres
DB_USER=postgres
DB_PASSWORD=your_secure_password
DB_HOST=localhost
DB_PORT=5432

# Option B: Connection String (Recommended for Supabase/Production)
# DB_URL=postgresql://user:password@host:port/dbname
